### New: `test_02` tightened lookahead tolerance

After confirming end-to-end determinism (same seed, same state, cache hit), tighten
test_2_2's tolerance:

```python
def test_2_2_lookahead_cost_is_exactly_007():
    """
    Pure Python scorer = exact arithmetic.
    Tolerance tightened from 0.015 to 0.001 after confirming determinism.
    Both calls use same seed → same G → same state → same base score → exact 0.07 diff.
    """
    from deal_room.rewards.utterance_scorer import LOOKAHEAD_COST
    BASE = os.environ.get("DEALROOM_BASE_URL", "http://127.0.0.1:7860")

    msg = "We have prepared a detailed ROI analysis for your review."

    requests.post(f"{BASE}/reset", json={"task": "aligned", "seed": 42})
    r1 = requests.post(f"{BASE}/step", json={
        "action_type": "direct_message", "target_ids": ["Finance"],
        "message": msg, "documents": [], "lookahead": None
    }, timeout=30)
    goal_base = float(r1.json().get("reward", 0))

    requests.post(f"{BASE}/reset", json={"task": "aligned", "seed": 42})
    r2 = requests.post(f"{BASE}/step", json={
        "action_type": "direct_message", "target_ids": ["Finance"],
        "message": msg, "documents": [],
        "lookahead": {"depth": 2, "n_hypotheses": 2, "action_draft": None}
    }, timeout=30)
    goal_with = float(r2.json().get("reward", 0))

    expected = max(0.0, goal_base - LOOKAHEAD_COST)
    assert abs(goal_with - expected) < 0.001, (
        f"Lookahead cost wrong.\n"
        f"  goal_base={goal_base:.4f}, goal_with={goal_with:.4f}\n"
        f"  expected={expected:.4f}, diff={abs(goal_with - expected):.6f}\n"
        f"  If diff > 0.001: check lookahead_was_requested extraction is FIRST line of step()"
    )
```

