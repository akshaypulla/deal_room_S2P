### New: `test_04` additions for Fix #1 (CVaR Veto Termination)

Add these three tests to `test_04_cvar_veto.py` after implementing `_check_veto_termination()`.

```python
def test_4_3_veto_terminates_episode():
    """
    After Fix #1: veto must set done=True and terminal_outcome='veto'.
    Previously warned — must now pass without warning.
    """
    BASE = os.environ.get("DEALROOM_BASE_URL", "http://127.0.0.1:7860")
    requests.post(f"{BASE}/reset", json={"task": "hostile_acquisition"})

    veto_fired = False
    for _ in range(20):
        r = requests.post(f"{BASE}/step", json={
            "action_type": "exec_escalation",
            "target_ids": ["Legal"],
            "message": "Legal must sign immediately or we withdraw all compliance commitments.",
            "documents": []
        }, timeout=30)
        result = r.json()
        obs = result.get("observation", result)
        if obs.get("done", False):
            terminal = result.get("info", {}).get("terminal_outcome", "")
            if "veto" in str(terminal).lower():
                veto_fired = True
            break

    assert veto_fired, (
        "Veto did not fire in 20 aggressive rounds of hostile_acquisition.\n"
        "Check: _check_veto_termination() called in step()?\n"
        "Check: veto_power=True on Legal and Finance in archetypes?"
    )


def test_4_8_veto_adds_terminal_penalty():
    """
    When veto fires, reward should include the terminal penalty (-1.0 * TERMINAL_WEIGHT).
    The step that triggers veto should have a lower total reward than normal steps.
    """
    from deal_room.rewards.utterance_scorer import LOOKAHEAD_COST
    from deal_room.environment.constants import TERMINAL_REWARDS, TERMINAL_WEIGHT

    BASE = os.environ.get("DEALROOM_BASE_URL", "http://127.0.0.1:7860")
    requests.post(f"{BASE}/reset", json={"task": "hostile_acquisition"})

    rewards = []
    terminal_reward = None
    for _ in range(20):
        r = requests.post(f"{BASE}/step", json={
            "action_type": "exec_escalation",
            "target_ids": ["Legal"],
            "message": "Sign immediately.",
            "documents": []
        }, timeout=30)
        result = r.json()
        obs = result.get("observation", result)
        reward = float(result.get("reward", 0))
        rewards.append(reward)
        if obs.get("done", False):
            terminal_reward = reward
            break

    if terminal_reward is not None:
        # Terminal step reward should reflect veto penalty
        expected_penalty = TERMINAL_WEIGHT * TERMINAL_REWARDS["veto"]   # -2.0
        # terminal_reward should be significantly lower than mid-episode rewards
        mid_episode_mean = sum(rewards[:-1]) / len(rewards[:-1]) if len(rewards) > 1 else 0
        assert terminal_reward < mid_episode_mean, (
            f"Terminal reward {terminal_reward:.3f} should be < mid-episode mean "
            f"{mid_episode_mean:.3f} when veto fires"
        )


def test_4_9_veto_stakeholder_identified_in_info():
    """
    info dict must contain terminal_outcome='veto' and veto_stakeholder=<sid>
    when veto terminates the episode.
    """
    BASE = os.environ.get("DEALROOM_BASE_URL", "http://127.0.0.1:7860")
    requests.post(f"{BASE}/reset", json={"task": "hostile_acquisition"})

    for _ in range(20):
        r = requests.post(f"{BASE}/step", json={
            "action_type": "exec_escalation",
            "target_ids": ["Legal"],
            "message": "Sign immediately.",
            "documents": []
        }, timeout=30)
        result = r.json()
        obs = result.get("observation", result)
        if obs.get("done", False):
            info = result.get("info", {})
            assert info.get("terminal_outcome") == "veto", (
                f"terminal_outcome should be 'veto', got {info.get('terminal_outcome')}"
            )
            assert info.get("veto_stakeholder") in ["Legal", "Finance", "ExecSponsor"], (
                f"veto_stakeholder should be a veto-power stakeholder, "
                f"got {info.get('veto_stakeholder')}"
            )
            return

    # If no veto in 20 rounds, skip (stochastic)
    pytest.skip("Veto not triggered in 20 rounds — stochastic environment")
```

