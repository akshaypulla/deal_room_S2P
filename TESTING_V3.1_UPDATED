### New: `test_01` update for Fix #2 (stakeholder_messages)

Replace `test_1_7` in `test_01_schema_validation.py` after implementing Fix #2:

```python
def test_1_7_stakeholder_messages_populated_after_step():
    """
    After Fix #2: stakeholder_messages must be non-empty after a step.
    Previously only checked it was a dict (always {}).
    Now verifies responses are actually in the observation.
    """
    BASE = os.environ.get("DEALROOM_BASE_URL", "http://127.0.0.1:7860")
    requests.post(f"{BASE}/reset", json={"task": "aligned"})
    r = requests.post(f"{BASE}/step", json={
        "action_type": "send_document",
        "target_ids": ["Legal"],
        "message": "Please find the DPA attached.",
        "documents": [{"name": "dpa", "content": "Standard DPA terms."}]
    }, timeout=30)
    obs = r.json().get("observation", r.json())
    messages = obs.get("stakeholder_messages", {})

    assert isinstance(messages, dict), "stakeholder_messages must be a dict"
    assert len(messages) > 0, (
        "stakeholder_messages is empty — Fix #2 not applied.\n"
        "Check: _build_observation() receives stakeholder_responses parameter."
    )
    for sid, msg in messages.items():
        assert msg, f"Empty message for stakeholder {sid}"
```

