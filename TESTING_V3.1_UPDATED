### New: `test_00` update for Fix #4 (Lazy API Key Validation)

Add to `test_00_environment_setup.py`:

```python
def test_0_6_environment_instantiates_without_api_key():
    """
    After Fix #4: DealRoomV3() must be instantiable without MINIMAX_API_KEY.
    Previously raised EnvironmentError at __init__.
    This unblocks container unit tests that don't make LLM calls.

    Run inside container: docker exec dealroom-v3-test python -c "..."
    """
    import subprocess
    result = subprocess.run(
        ["docker", "exec", "dealroom-v3-test",
         "python", "-c",
         "import os; "
         "del os.environ['MINIMAX_API_KEY'] if 'MINIMAX_API_KEY' in os.environ else None; "
         "from deal_room.environment.dealroom_v3 import DealRoomV3; "
         "env = DealRoomV3(); "
         "print('PASSED: DealRoomV3 instantiated without API key')"],
        capture_output=True, text=True, timeout=30
    )
    assert "PASSED" in result.stdout, (
        f"DealRoomV3 still raises on instantiation without API key.\n"
        f"stdout: {result.stdout}\nstderr: {result.stderr}\n"
        f"Fix #4 not applied: validate_api_keys() still in __init__."
    )
```

