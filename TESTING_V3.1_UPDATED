### New: `test_scorer_unit.py` additions

Add to `test_scorer_unit.py`:

```python
def test_lookahead_cost_imported_not_hardcoded():
    """
    LOOKAHEAD_COST must be importable from utterance_scorer.
    All other files import from here — no hardcoded 0.07 elsewhere.
    """
    from deal_room.rewards.utterance_scorer import LOOKAHEAD_COST
    assert LOOKAHEAD_COST == 0.07
    # Verify no other definition exists
    import subprocess
    result = subprocess.run(
        ["grep", "-rn", "LOOKAHEAD_COST\\s*=", "deal_room/", "tests/"],
        capture_output=True, text=True
    )
    definitions = [l for l in result.stdout.strip().split('\n')
                   if l and '= 0.07' in l and 'import' not in l]
    assert len(definitions) == 1, (
        f"LOOKAHEAD_COST defined in multiple places: {definitions}\n"
        "Should be defined only in utterance_scorer.py"
    )


def test_reward_weights_not_simple_average():
    """
    _compute_reward must use weighted_sum(REWARD_WEIGHTS), not /5.0.
    Verify by checking that causal weight is 0.15, not 0.20.
    """
    from deal_room.rewards.utterance_scorer import UtteranceScorer
    from deal_room.environment.constants import REWARD_WEIGHTS

    # If simple average, all weights = 0.20
    # Causal must be 0.15 (intentionally lower)
    assert REWARD_WEIGHTS["causal"] == 0.15, (
        f"causal weight is {REWARD_WEIGHTS['causal']}, expected 0.15. "
        "Check that weighted_sum is used, not /5.0."
    )
    assert REWARD_WEIGHTS["goal"] == 0.25, (
        f"goal weight is {REWARD_WEIGHTS['goal']}, expected 0.25."
    )
    assert abs(sum(REWARD_WEIGHTS.values()) - 1.0) < 1e-6, (
        "REWARD_WEIGHTS must sum to 1.0"
    )
```

