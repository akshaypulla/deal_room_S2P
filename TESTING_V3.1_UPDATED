## Updated Test 11 for Post-Fix Validation

After applying all four fixes, add P13 and P14 to `test_11_research_properties.py`:

```python
def p13_veto_terminates_episode():
    """
    P13 (new): CVaR veto must set done=True.
    Requires Fix #1 applied.
    """
    BASE = os.environ.get("DEALROOM_BASE_URL", "http://127.0.0.1:7860")
    requests.post(f"{BASE}/reset", json={"task": "hostile_acquisition"})
    for _ in range(20):
        r = requests.post(f"{BASE}/step", json={
            "action_type": "exec_escalation",
            "target_ids": ["Legal"],
            "message": "Sign now.", "documents": []
        }, timeout=30)
        obs = r.json().get("observation", r.json())
        if obs.get("done", False):
            info = r.json().get("info", {})
            assert info.get("terminal_outcome") == "veto"
            return
    pytest.skip("Veto not triggered stochastically")


def p14_agent_reads_stakeholder_responses():
    """
    P14 (new): stakeholder_messages must be non-empty after a step.
    Requires Fix #2 applied.
    """
    BASE = os.environ.get("DEALROOM_BASE_URL", "http://127.0.0.1:7860")
    requests.post(f"{BASE}/reset", json={"task": "aligned"})
    r = requests.post(f"{BASE}/step", json={
        "action_type": "send_document",
        "target_ids": ["Legal"],
        "message": "DPA attached.", "documents": [{"name": "dpa", "content": "..."}]
    }, timeout=30)
    obs = r.json().get("observation", r.json())
    messages = obs.get("stakeholder_messages", {})
    assert len(messages) > 0, "stakeholder_messages empty — Fix #2 not applied"
```

